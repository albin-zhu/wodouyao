{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "wodouyao terminal set-session \"$CLAUDE_SESSION_ID\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(wodouyao peers *)",
      "Bash(wodouyao send *)",
      "Bash(wodouyao read *)"
    ]
  }
}