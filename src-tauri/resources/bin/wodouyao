#!/bin/sh
# wodouyao — CLI wrapper around the in-process wodouyao hub HTTP API.
# Strict POSIX sh, no bashisms.
set -eu

SELF=wodouyao

die() { printf '%s: %s\n' "$SELF" "$1" >&2; exit "${2:-1}"; }

usage() {
    cat >&2 <<'EOF'
Usage: wodouyao <subcommand> [args]
  peers                              list peer terminal ids (one per line)
  whoami                             print this terminal's registered identity
  hello [--name N] [--kind K] [--caps a,b,c]
                                     register this terminal's identity
  spawn [--name N] [--kind K] [--command C] [--cwd P] [--no-wire]
        [--team T] [--team-role R]
                                     create a new terminal (auto-wired from caller
                                     by default); prints the new id on stdout
  fork --kind claude|codex [--name N] [--peer <id>]
                                     resume the caller's (or --peer's) agent
                                     session in a new terminal at $(pwd) and
                                     drive its /fork slash command. Requires
                                     --kind because the hub doesn't track which
                                     CLI a terminal is currently running.
  send <peer> [--raw|--keys] <text>  send text (keys mode always appends Enter)
  read <peer> [--bytes N]            read recent output (default N=16384)
  watch <peer>                       stream a peer's output until Ctrl+C
  task list                          list all global tasks
  task add "<subject>" [--desc "..."] [--blocked-by id,id]
                                     create a task; prints new task id
  task take <task-id>                claim a task (owner + in_progress)
  task done <task-id>                mark a task completed
  task update <task-id> [--status S] [--owner O] [--desc D]
                                     patch a task
  task remove <task-id>              delete a task
  wire list                          list all wires
  wire add <source-id> <target-id> [--kind K]
                                     create a wire
  wire remove <wire-id>              remove a wire
  note list                          list all notes
  note add "<text>" [--color C]      create a note
  note update <note-id> "<text>"     update note text
  note remove <note-id>              remove a note
  terminal list                      list all live terminals
  terminal close <terminal-id>       close a terminal
  bg get                             print current background settings JSON
  bg set <kind> [--source S] [--shader N] [--opacity F]
                                     set canvas background
                                     kind: none|image|video|url|shader
  bg shaders                         list available shader names
  team create <name> [--palette K] [--as-lead]
                                     create a team; prints new team id
  team list                          list teams, one per line
  team info <name-or-id>             pretty-print team JSON
  team join <name-or-id> [--role R]  join a team
  team leave <name-or-id>            leave a team
  team dissolve <name-or-id>         dissolve a team
  team task add <team> "<subject>" [--desc "..."] [--blocked-by id,id]
                                     create a team task; prints new task id
  team task list <team>              list team tasks
  team task take <team> <task-id>    claim a task (sets owner + in_progress)
  team task done <team> <task-id>    mark a task completed
  team task assign <team> <task-id> <peer-id>
                                     assign a task to a peer
  team bcast <team> "<msg>"          broadcast to all team members
  team dm <team> <role> "<msg>"      direct message members by role
EOF
    exit "${1:-1}"
}

# extract_field <key> <file> — pull a string field from a flat JSON object.
extract_field() {
    _f=$1; _file=$2
    if command -v python3 >/dev/null 2>&1; then
        python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))[sys.argv[2]])' \
            "$_file" "$_f" 2>/dev/null
    else
        grep -o "\"$_f\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$_file" 2>/dev/null \
            | sed "s/.*\"$_f\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/"
    fi
}

# json_escape <string> — emit a JSON string literal (including surrounding quotes).
json_escape() {
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$1" | python3 -c 'import json,sys;sys.stdout.write(json.dumps(sys.stdin.read()))'
    else
        # Fallback: escape backslash then double-quote; wrap in quotes.
        printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e '1s/^/"/' -e '$s/$/"/'
    fi
}

load_endpoint() {
    if [ -z "${WODOUYAO_ENDPOINT:-}" ] || [ -z "${WODOUYAO_ID:-}" ]; then
        die "not running inside a wodouyao terminal" 2
    fi
    [ -r "$WODOUYAO_ENDPOINT" ] || die "malformed endpoint file" 3
    URL=$(extract_field url "$WODOUYAO_ENDPOINT") || die "malformed endpoint file" 3
    TOKEN=$(extract_field token "$WODOUYAO_ENDPOINT") || die "malformed endpoint file" 3
    [ -n "$URL" ] && [ -n "$TOKEN" ] || die "malformed endpoint file" 3
}

curl_auth() { curl -sS -H "Authorization: Bearer $TOKEN" "$@"; }

cmd_peers() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/peers?from=$WODOUYAO_ID") \
        || die "failed to fetch peers"
    # Response is now a JSON array of identity objects. Extract .id from each.
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
for e in json.load(sys.stdin):
    print(e.get("id", ""))
'
    else
        # POSIX fallback: grep every `"id":"..."` occurrence.
        printf '%s' "$_body" \
            | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' \
            | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
    fi
}

cmd_whoami() {
    load_endpoint
    curl_auth -f "$URL/v1/whoami?id=$WODOUYAO_ID" || die "whoami failed"
    printf '\n'
}

cmd_hello() {
    _name=""
    _kind=""
    _caps=""
    while [ $# -gt 0 ]; do
        case $1 in
            --name) [ $# -ge 2 ] || die "--name requires a value"
                    _name=$2; shift 2 ;;
            --kind) [ $# -ge 2 ] || die "--kind requires a value"
                    _kind=$2; shift 2 ;;
            --caps) [ $# -ge 2 ] || die "--caps requires a comma-separated list"
                    _caps=$2; shift 2 ;;
            *) die "unknown argument: $1" ;;
        esac
    done
    load_endpoint
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_HELLO_ID=$WODOUYAO_ID \
                WODOUYAO_HELLO_NAME=$_name \
                WODOUYAO_HELLO_KIND=$_kind \
                WODOUYAO_HELLO_CAPS=$_caps \
                python3 -c '
import json, os
caps = os.environ.get("WODOUYAO_HELLO_CAPS", "")
caps_list = [c.strip() for c in caps.split(",") if c.strip()]
obj = {"id": os.environ["WODOUYAO_HELLO_ID"]}
name = os.environ.get("WODOUYAO_HELLO_NAME", "")
kind = os.environ.get("WODOUYAO_HELLO_KIND", "")
if name:
    obj["name"] = name
if kind:
    obj["agent_kind"] = kind
if caps_list:
    obj["capabilities"] = caps_list
print(json.dumps(obj))
')
    else
        _name_j=$(json_escape "$_name")
        _kind_j=$(json_escape "$_kind")
        # Fallback: caps becomes ["a","b"] via awk.
        _caps_j=$(printf '%s' "$_caps" \
            | awk -F, 'BEGIN{printf "["} {for(i=1;i<=NF;i++){if($i!=""){if(out)printf ",";printf "\"%s\"",$i;out=1}}} END{printf "]"}')
        _body=$(printf '{"id":"%s","name":%s,"agent_kind":%s,"capabilities":%s}' \
            "$WODOUYAO_ID" "$_name_j" "$_kind_j" "$_caps_j")
    fi
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/self") || die "hello failed"
    [ "$_code" = 200 ] || die "hello failed (HTTP $_code)"
}

cmd_send() {
    [ $# -gt 0 ] || usage
    _peer=$1; shift
    _mode=keys
    while [ $# -gt 0 ]; do
        case $1 in
            --raw)       _mode=raw; shift ;;
            --keys)      _mode=keys; shift ;;
            --)          shift; break ;;
            -*)          die "unknown flag: $1" ;;
            *)           break ;;
        esac
    done
    [ $# -gt 0 ] || die "send: missing text"
    _text=$*
    # Enter is ALWAYS appended in keys mode. Every modern agent CLI
    # (Claude Code, codex, opencode) queues messages internally, so a
    # trailing Enter never breaks in-progress work — but forgetting it
    # silently swallows the message. No opt-out.
    load_endpoint
    _encoded=$(json_escape "$_text")
    _body=$(printf '{"from":"%s","to":"%s","text":%s,"mode":"%s"}' \
        "$WODOUYAO_ID" "$_peer" "$_encoded" "$_mode")
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/send") || die "send failed"
    case $_code in
        204) : ;;
        403) printf '%s: no wire to %s\n' "$SELF" "$_peer" >&2; exit 4 ;;
        *)   die "send failed (HTTP $_code)" ;;
    esac
}

cmd_read() {
    [ $# -gt 0 ] || usage
    _peer=$1; shift
    _bytes=16384
    while [ $# -gt 0 ]; do
        case $1 in
            --bytes) [ $# -ge 2 ] || die "--bytes requires a value"
                     _bytes=$2; shift 2 ;;
            *) die "unknown argument: $1" ;;
        esac
    done
    load_endpoint
    curl_auth -f "$URL/v1/read?from=$WODOUYAO_ID&to=$_peer&bytes=$_bytes" \
        || die "read failed"
}

cmd_watch() {
    [ $# -gt 0 ] || usage
    _peer=$1; shift
    load_endpoint
    # -N disables curl's output buffering so chunks stream through as they
    # arrive. -f makes curl fail early on HTTP 4xx/5xx. The server closes the
    # connection when the peer session ends; otherwise the user Ctrl+Cs.
    curl_auth -fN "$URL/v1/watch?from=$WODOUYAO_ID&to=$_peer"
}

# resolve_team_id <name-or-id> — echo team id to stdout; exit 4 if not found.
resolve_team_id() {
    _arg=$1
    # Looks like an id already (team_<hex>): pass through.
    case $_arg in
        team_*)
            _rest=${_arg#team_}
            if printf '%s' "$_rest" | grep -Eq '^[a-f0-9]+$'; then
                printf '%s' "$_arg"
                return 0
            fi
            ;;
    esac
    _list=$(curl_auth -f "$URL/v1/teams") || die "team lookup failed"
    if command -v python3 >/dev/null 2>&1; then
        _found=$(printf '%s' "$_list" | \
            WODOUYAO_LOOKUP_NAME=$_arg python3 -c '
import json, os, sys
name = os.environ["WODOUYAO_LOOKUP_NAME"]
try:
    teams = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for t in teams:
    if t.get("name") == name or t.get("id") == name:
        print(t.get("id", ""))
        break
')
    else
        _found=$(printf '%s' "$_list" | tr ',' '\n' \
            | awk -v n="$_arg" '
                /"id"[[:space:]]*:[[:space:]]*"/ {
                    sub(/.*"id"[[:space:]]*:[[:space:]]*"/, ""); sub(/".*/, "");
                    id=$0; next
                }
                /"name"[[:space:]]*:[[:space:]]*"/ {
                    sub(/.*"name"[[:space:]]*:[[:space:]]*"/, ""); sub(/".*/, "");
                    if ($0==n) { print id; exit }
                }')
    fi
    [ -n "$_found" ] || { printf '%s: team not found: %s\n' "$SELF" "$_arg" >&2; exit 4; }
    printf '%s' "$_found"
}

cmd_team_create() {
    _name=""
    _palette=""
    _as_lead=0
    while [ $# -gt 0 ]; do
        case $1 in
            --palette) [ $# -ge 2 ] || die "--palette requires a value"
                       _palette=$2; shift 2 ;;
            --as-lead) _as_lead=1; shift ;;
            -*)        die "unknown flag: $1" ;;
            *)         [ -z "$_name" ] || die "team create: multiple names given"
                       _name=$1; shift ;;
        esac
    done
    [ -n "$_name" ] || die "team create: missing <name>"
    load_endpoint
    _lead=""
    if [ "$_as_lead" = 1 ]; then
        _lead=$WODOUYAO_ID
    fi
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_T_NAME=$_name \
                WODOUYAO_T_PALETTE=$_palette \
                WODOUYAO_T_LEAD=$_lead \
                python3 -c '
import json, os
obj = {"name": os.environ["WODOUYAO_T_NAME"]}
p = os.environ.get("WODOUYAO_T_PALETTE", "")
if p:
    obj["palette"] = p
lead = os.environ.get("WODOUYAO_T_LEAD", "")
if lead:
    obj["lead"] = lead
print(json.dumps(obj))
')
    else
        _name_j=$(json_escape "$_name")
        _body="{\"name\":$_name_j"
        if [ -n "$_palette" ]; then
            _p_j=$(json_escape "$_palette")
            _body="$_body,\"palette\":$_p_j"
        fi
        if [ -n "$_lead" ]; then
            _l_j=$(json_escape "$_lead")
            _body="$_body,\"lead\":$_l_j"
        fi
        _body="$_body}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/teams") \
        || { rm -f "$_tmp"; die "team create failed"; }
    case $_code in
        200|201)
            _id=$(extract_field id "$_tmp")
            rm -f "$_tmp"
            [ -n "$_id" ] || die "team create: response missing id"
            printf '%s\n' "$_id"
            ;;
        409) _err=$(cat "$_tmp"); rm -f "$_tmp"
             printf '%s: team name already exists: %s\n' "$SELF" "$_name" >&2; exit 4 ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "team create failed (HTTP $_code): $_err" ;;
    esac
}

cmd_team_list() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/teams") || die "team list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    teams = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for t in teams:
    pid = (t.get("palette") or {})
    pkey = pid.get("key") if isinstance(pid, dict) else pid
    members = t.get("members") or []
    print("%s  %s  %d members  palette=%s" % (
        t.get("id", ""), t.get("name", ""), len(members), pkey or ""))
'
    else
        # Crude fallback: emit one raw object per line.
        printf '%s\n' "$_body"
    fi
}

cmd_team_info() {
    [ $# -gt 0 ] || die "team info: missing <name-or-id>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _body=$(curl_auth -f "$URL/v1/teams/$_id") || die "team info failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -m json.tool
    else
        printf '%s\n' "$_body"
    fi
}

# _post_team_action <id> <action> <body> — POST to /v1/teams/<id>/<action>.
_post_team_action() {
    _id=$1; _action=$2; _body=$3
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/teams/$_id/$_action") \
        || { rm -f "$_tmp"; die "team $_action failed"; }
    case $_code in
        200|204) rm -f "$_tmp" ;;
        404)     rm -f "$_tmp"
                 printf '%s: team not found: %s\n' "$SELF" "$_id" >&2; exit 4 ;;
        409)     _err=$(cat "$_tmp"); rm -f "$_tmp"
                 printf '%s: team %s rejected (409): %s\n' "$SELF" "$_action" "$_err" >&2
                 exit 4 ;;
        *)       _err=$(cat "$_tmp"); rm -f "$_tmp"
                 die "team $_action failed (HTTP $_code): $_err" ;;
    esac
}

cmd_team_join() {
    _target=""
    _role=""
    while [ $# -gt 0 ]; do
        case $1 in
            --role) [ $# -ge 2 ] || die "--role requires a value"
                    _role=$2; shift 2 ;;
            -*)     die "unknown flag: $1" ;;
            *)      [ -z "$_target" ] || die "team join: multiple targets"
                    _target=$1; shift ;;
        esac
    done
    [ -n "$_target" ] || die "team join: missing <name-or-id>"
    load_endpoint
    _id=$(resolve_team_id "$_target")
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_T_TERM=$WODOUYAO_ID \
                WODOUYAO_T_ROLE=$_role \
                python3 -c '
import json, os
obj = {"term_id": os.environ["WODOUYAO_T_TERM"]}
r = os.environ.get("WODOUYAO_T_ROLE", "")
if r:
    obj["role"] = r
print(json.dumps(obj))
')
    else
        _t_j=$(json_escape "$WODOUYAO_ID")
        _body="{\"term_id\":$_t_j"
        if [ -n "$_role" ]; then
            _r_j=$(json_escape "$_role")
            _body="$_body,\"role\":$_r_j"
        fi
        _body="$_body}"
    fi
    _post_team_action "$_id" join "$_body"
}

cmd_team_leave() {
    [ $# -gt 0 ] || die "team leave: missing <name-or-id>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _t_j=$(json_escape "$WODOUYAO_ID")
    _body="{\"term_id\":$_t_j}"
    _post_team_action "$_id" leave "$_body"
}

cmd_team_dissolve() {
    [ $# -gt 0 ] || die "team dissolve: missing <name-or-id>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _post_team_action "$_id" dissolve "{}"
}

# _patch_team_task <team-id> <task-id> <body> — PATCH /v1/teams/<id>/tasks/<tid>.
_patch_team_task() {
    _id=$1; _tid=$2; _body=$3
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X PATCH -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/teams/$_id/tasks/$_tid") \
        || { rm -f "$_tmp"; die "task patch failed"; }
    case $_code in
        200|204) rm -f "$_tmp" ;;
        404)     rm -f "$_tmp"
                 printf '%s: task not found: %s\n' "$SELF" "$_tid" >&2; exit 4 ;;
        *)       _err=$(cat "$_tmp"); rm -f "$_tmp"
                 die "task patch failed (HTTP $_code): $_err" ;;
    esac
}

cmd_team_task_add() {
    _team=""
    _subject=""
    _desc=""
    _blocked=""
    while [ $# -gt 0 ]; do
        case $1 in
            --desc)       [ $# -ge 2 ] || die "--desc requires a value"
                          _desc=$2; shift 2 ;;
            --blocked-by) [ $# -ge 2 ] || die "--blocked-by requires a value"
                          _blocked=$2; shift 2 ;;
            -*)           die "unknown flag: $1" ;;
            *)            if [ -z "$_team" ]; then _team=$1
                          elif [ -z "$_subject" ]; then _subject=$1
                          else die "team task add: too many arguments"
                          fi
                          shift ;;
        esac
    done
    [ -n "$_team" ] || die "team task add: missing <team>"
    [ -n "$_subject" ] || die "team task add: missing <subject>"
    load_endpoint
    _id=$(resolve_team_id "$_team")
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_T_SUBJ=$_subject \
                WODOUYAO_T_DESC=$_desc \
                WODOUYAO_T_BY=$WODOUYAO_ID \
                WODOUYAO_T_BLOCK=$_blocked \
                python3 -c '
import json, os
obj = {"subject": os.environ["WODOUYAO_T_SUBJ"],
       "created_by": os.environ["WODOUYAO_T_BY"]}
d = os.environ.get("WODOUYAO_T_DESC", "")
if d:
    obj["description"] = d
b = os.environ.get("WODOUYAO_T_BLOCK", "")
blk = [x.strip() for x in b.split(",") if x.strip()]
if blk:
    obj["blocked_by"] = blk
print(json.dumps(obj))
')
    else
        _s_j=$(json_escape "$_subject")
        _by_j=$(json_escape "$WODOUYAO_ID")
        _body="{\"subject\":$_s_j,\"created_by\":$_by_j"
        if [ -n "$_desc" ]; then
            _d_j=$(json_escape "$_desc")
            _body="$_body,\"description\":$_d_j"
        fi
        if [ -n "$_blocked" ]; then
            _blk_j=$(printf '%s' "$_blocked" \
                | awk -F, 'BEGIN{printf "["} {for(i=1;i<=NF;i++){if($i!=""){if(out)printf ",";printf "\"%s\"",$i;out=1}}} END{printf "]"}')
            _body="$_body,\"blocked_by\":$_blk_j"
        fi
        _body="$_body}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/teams/$_id/tasks") \
        || { rm -f "$_tmp"; die "team task add failed"; }
    case $_code in
        200|201)
            _tid=$(extract_field id "$_tmp")
            rm -f "$_tmp"
            [ -n "$_tid" ] || die "team task add: response missing id"
            printf '%s\n' "$_tid"
            ;;
        404) rm -f "$_tmp"
             printf '%s: team not found: %s\n' "$SELF" "$_team" >&2; exit 4 ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "team task add failed (HTTP $_code): $_err" ;;
    esac
}

cmd_team_task_list() {
    [ $# -gt 0 ] || die "team task list: missing <team>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _body=$(curl_auth -f "$URL/v1/teams/$_id/tasks") || die "team task list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    tasks = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for t in tasks:
    line = "%s  %s  %s" % (
        t.get("id", ""), t.get("status", ""), t.get("subject", ""))
    owner = t.get("owner") or ""
    if owner:
        line += "  [owner=%s]" % owner
    print(line)
'
    else
        printf '%s\n' "$_body"
    fi
}

cmd_team_task_take() {
    [ $# -ge 2 ] || die "team task take: usage <team> <task-id>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _tid=$2
    _by_j=$(json_escape "$WODOUYAO_ID")
    _body="{\"owner\":$_by_j,\"status\":\"in_progress\"}"
    _patch_team_task "$_id" "$_tid" "$_body"
}

cmd_team_task_done() {
    [ $# -ge 2 ] || die "team task done: usage <team> <task-id>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _tid=$2
    _patch_team_task "$_id" "$_tid" '{"status":"completed"}'
}

cmd_team_task_assign() {
    [ $# -ge 3 ] || die "team task assign: usage <team> <task-id> <peer-id>"
    load_endpoint
    _id=$(resolve_team_id "$1")
    _tid=$2
    _peer=$3
    _p_j=$(json_escape "$_peer")
    _body="{\"owner\":$_p_j}"
    _patch_team_task "$_id" "$_tid" "$_body"
}

cmd_team_task() {
    [ $# -gt 0 ] || die "team task: missing subcommand (add|list|take|done|assign)"
    _sub=$1; shift
    case $_sub in
        add)    cmd_team_task_add    "$@" ;;
        list)   cmd_team_task_list   "$@" ;;
        take)   cmd_team_task_take   "$@" ;;
        done)   cmd_team_task_done   "$@" ;;
        assign) cmd_team_task_assign "$@" ;;
        *)      die "team task: unknown subcommand: $_sub" ;;
    esac
}

cmd_team_bcast() {
    [ $# -ge 2 ] || die "team bcast: usage <team> <msg>"
    _team=$1; shift
    _text=$*
    load_endpoint
    _id=$(resolve_team_id "$_team")
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_T_FROM=$WODOUYAO_ID \
                WODOUYAO_T_TEXT=$_text \
                python3 -c '
import json, os
print(json.dumps({
    "from": os.environ["WODOUYAO_T_FROM"],
    "text": os.environ["WODOUYAO_T_TEXT"],
    "mode": "keys",
}))
')
    else
        _from_j=$(json_escape "$WODOUYAO_ID")
        _text_j=$(json_escape "$_text")
        _body=$(printf '{"from":%s,"text":%s,"mode":"keys"}' "$_from_j" "$_text_j")
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/teams/$_id/broadcast") \
        || { rm -f "$_tmp"; die "team bcast failed"; }
    case $_code in
        200|204)
            if command -v python3 >/dev/null 2>&1; then
                _failed=$(python3 -c '
import json, sys
try:
    r = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
f = r.get("failed") or []
if f:
    print(",".join(str(x) for x in f))
' "$_tmp" 2>/dev/null)
                if [ -n "$_failed" ]; then
                    printf '%s: bcast partial failure: %s\n' "$SELF" "$_failed" >&2
                fi
            fi
            rm -f "$_tmp"
            ;;
        404) rm -f "$_tmp"
             printf '%s: team not found: %s\n' "$SELF" "$_team" >&2; exit 4 ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "team bcast failed (HTTP $_code): $_err" ;;
    esac
}

cmd_team_dm() {
    [ $# -ge 3 ] || die "team dm: usage <team> <role> <msg>"
    _team=$1; shift
    _role=$1; shift
    _text=$*
    load_endpoint
    _id=$(resolve_team_id "$_team")
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_T_FROM=$WODOUYAO_ID \
                WODOUYAO_T_ROLE=$_role \
                WODOUYAO_T_TEXT=$_text \
                python3 -c '
import json, os
print(json.dumps({
    "from": os.environ["WODOUYAO_T_FROM"],
    "to_role": os.environ["WODOUYAO_T_ROLE"],
    "text": os.environ["WODOUYAO_T_TEXT"],
    "mode": "keys",
}))
')
    else
        _from_j=$(json_escape "$WODOUYAO_ID")
        _role_j=$(json_escape "$_role")
        _text_j=$(json_escape "$_text")
        _body=$(printf '{"from":%s,"to_role":%s,"text":%s,"mode":"keys"}' \
            "$_from_j" "$_role_j" "$_text_j")
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/teams/$_id/dm") \
        || { rm -f "$_tmp"; die "team dm failed"; }
    case $_code in
        200|204)
            if command -v python3 >/dev/null 2>&1; then
                _failed=$(python3 -c '
import json, sys
try:
    r = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
f = r.get("failed") or []
if f:
    print(",".join(str(x) for x in f))
' "$_tmp" 2>/dev/null)
                if [ -n "$_failed" ]; then
                    printf '%s: dm partial failure: %s\n' "$SELF" "$_failed" >&2
                fi
            fi
            rm -f "$_tmp"
            ;;
        404) rm -f "$_tmp"
             printf '%s: team not found: %s\n' "$SELF" "$_team" >&2; exit 4 ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "team dm failed (HTTP $_code): $_err" ;;
    esac
}

cmd_team() {
    [ $# -gt 0 ] || die "team: missing subcommand (create|list|info|join|leave|dissolve|task|bcast|dm)"
    _sub=$1; shift
    case $_sub in
        create)   cmd_team_create   "$@" ;;
        list)     cmd_team_list     "$@" ;;
        info)     cmd_team_info     "$@" ;;
        join)     cmd_team_join     "$@" ;;
        leave)    cmd_team_leave    "$@" ;;
        dissolve) cmd_team_dissolve "$@" ;;
        task)     cmd_team_task     "$@" ;;
        bcast)    cmd_team_bcast    "$@" ;;
        dm)       cmd_team_dm       "$@" ;;
        *)        die "team: unknown subcommand: $_sub" ;;
    esac
}

cmd_spawn() {
    _name=""
    _kind=""
    _command=""
    _cwd=""
    _team=""
    _team_role=""
    _wire=1
    while [ $# -gt 0 ]; do
        case $1 in
            --name)      [ $# -ge 2 ] || die "--name requires a value"
                         _name=$2; shift 2 ;;
            --kind)      [ $# -ge 2 ] || die "--kind requires a value"
                         _kind=$2; shift 2 ;;
            --command)   [ $# -ge 2 ] || die "--command requires a value"
                         _command=$2; shift 2 ;;
            --cwd)       [ $# -ge 2 ] || die "--cwd requires a value"
                         _cwd=$2; shift 2 ;;
            --team)      [ $# -ge 2 ] || die "--team requires a value"
                         _team=$2; shift 2 ;;
            --team-role) [ $# -ge 2 ] || die "--team-role requires a value"
                         _team_role=$2; shift 2 ;;
            --no-wire)   _wire=0; shift ;;
            *) die "unknown argument: $1" ;;
        esac
    done
    load_endpoint

    # Default command from kind if not explicitly set
    if [ -n "$_kind" ] && [ -z "$_command" ]; then
        case "$_kind" in
            claude)
                _prompt_file=$(mktemp "${TMPDIR:-/tmp}/wodouyao_prompt_XXXXXX.md")
                _agent_name="${_name:-Agent}"
                cat > "$_prompt_file" << ROLEEOF
# Role: $_agent_name

You are running inside a Wodouyao canvas terminal as **$_agent_name**.

## Startup (run these NOW)

\`\`\`sh
wodouyao hello --name "$_agent_name" --kind claude
wodouyao task list
\`\`\`

## Key Commands

- \`wodouyao peers\` — list connected peers
- \`wodouyao task list\` — view tasks
- \`wodouyao task take <id>\` — claim a task
- \`wodouyao task done <id>\` — mark complete
- \`wodouyao send <peer> "text" Enter\` — send to peer
- \`wodouyao read <peer>\` — read peer output
- \`wodouyao note add "text"\` — add a sticky note

## Workflow

1. Register identity (hello)
2. Check task list
3. Claim an unclaimed task (take)
4. Complete the work
5. Mark done, then check for more tasks
ROLEEOF
                # Convert to mixed Windows path if on MSYS/Git Bash
                if command -v cygpath >/dev/null 2>&1; then
                    _prompt_path=$(cygpath -m "$_prompt_file")
                else
                    _prompt_path="$_prompt_file"
                fi
                _command="claude --dangerously-skip-permissions \"@${_prompt_path}\""
                ;;
            codex)  _command="codex" ;;
            opencode) _command="opencode" ;;
        esac
    fi
    # Default cwd to current directory if not specified
    if [ -z "$_cwd" ]; then
        _cwd="$(pwd)"
    fi

    if [ "$_wire" = 1 ]; then
        _from=$WODOUYAO_ID
    else
        _from=""
    fi

    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_SPAWN_NAME=$_name \
                WODOUYAO_SPAWN_KIND=$_kind \
                WODOUYAO_SPAWN_CMD=$_command \
                WODOUYAO_SPAWN_CWD=$_cwd \
                WODOUYAO_SPAWN_FROM=$_from \
                WODOUYAO_SPAWN_TEAM=$_team \
                WODOUYAO_SPAWN_TEAM_ROLE=$_team_role \
                python3 -c '
import json, os
obj = {}
for key, env in [
    ("name",           "WODOUYAO_SPAWN_NAME"),
    ("kind",           "WODOUYAO_SPAWN_KIND"),
    ("command",        "WODOUYAO_SPAWN_CMD"),
    ("cwd",            "WODOUYAO_SPAWN_CWD"),
    ("auto_wire_from", "WODOUYAO_SPAWN_FROM"),
    ("team",           "WODOUYAO_SPAWN_TEAM"),
    ("team_role",      "WODOUYAO_SPAWN_TEAM_ROLE"),
]:
    v = os.environ.get(env, "")
    if v:
        obj[key] = v
print(json.dumps(obj))
')
    else
        # Minimal fallback: manual JSON assembly without embedded quotes in values.
        _body="{"
        _sep=""
        _append() {
            _k=$1; _v=$2
            [ -n "$_v" ] || return 0
            _vj=$(printf '%s' "$_v" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
            _body="$_body$_sep\"$_k\":\"$_vj\""
            _sep=","
        }
        _append name           "$_name"
        _append kind           "$_kind"
        _append command        "$_command"
        _append cwd            "$_cwd"
        _append auto_wire_from "$_from"
        _append team           "$_team"
        _append team_role      "$_team_role"
        _body="$_body}"
    fi

    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/spawn") || { rm -f "$_tmp"; die "spawn failed"; }
    case $_code in
        200) cat "$_tmp"; printf '\n' ;;
        503) rm -f "$_tmp"; die "spawn failed: frontend not ready yet (try again in a moment)" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "spawn failed (HTTP $_code): $_err" ;;
    esac
    rm -f "$_tmp"
}

cmd_fork() {
    _name=""
    _kind=""
    _from="$WODOUYAO_ID"
    while [ $# -gt 0 ]; do
        case $1 in
            --name)  [ $# -ge 2 ] || die "--name requires a value"
                     _name=$2; shift 2 ;;
            --kind)  [ $# -ge 2 ] || die "--kind requires a value"
                     _kind=$2; shift 2 ;;
            --peer)  [ $# -ge 2 ] || die "--peer requires a value"
                     _from=$2; shift 2 ;;
            *) die "unknown argument: $1" ;;
        esac
    done
    [ -n "$_from" ] || die "fork: missing source terminal id (set WODOUYAO_ID or pass --peer)"
    if [ -z "$_kind" ]; then
        die "fork: --kind required (claude|codex)"
    fi
    load_endpoint

    _cwd=$(pwd)
    _name_j=$(json_escape "$_name")
    _kind_j=$(json_escape "$_kind")
    _from_j=$(json_escape "$_from")
    _cwd_j=$(json_escape "$_cwd")
    if [ -z "$_name" ]; then
        _body=$(printf '{"from":%s,"kind":%s,"cwd":%s}' "$_from_j" "$_kind_j" "$_cwd_j")
    else
        _body=$(printf '{"from":%s,"kind":%s,"cwd":%s,"name":%s}' \
            "$_from_j" "$_kind_j" "$_cwd_j" "$_name_j")
    fi

    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/fork") || { rm -f "$_tmp"; die "fork failed"; }
    case $_code in
        200) _new_id=$(extract_field id "$_tmp")
             rm -f "$_tmp"
             [ -n "$_new_id" ] || die "fork: hub returned no id"
             # Wait for the resumed agent to come up, then drive its
             # /fork slash command. 1.5s is a reasonable starting point;
             # claude / codex usually print their prompt within a second.
             sleep 1.5
             if [ -n "$_name" ]; then
                 cmd_send "$_new_id" "/fork \"$_name\""
             else
                 cmd_send "$_new_id" "/fork"
             fi
             printf '%s\n' "$_new_id" ;;
        503) rm -f "$_tmp"; die "fork failed: frontend not ready yet (try again in a moment)" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "fork failed (HTTP $_code): $_err" ;;
    esac
}

# ── Global task commands ─────────────────────────────────────────────

cmd_task_list() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/tasks") || die "task list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    tasks = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for t in tasks:
    line = "%s  %s  %s" % (
        t.get("id", ""), t.get("status", ""), t.get("subject", ""))
    owner = t.get("owner_term_id") or ""
    if owner:
        line += "  [owner=%s]" % owner
    print(line)
'
    else
        printf '%s\n' "$_body"
    fi
}

cmd_task_add() {
    _subject=""
    _desc=""
    _blocked=""
    _role_hint=""
    while [ $# -gt 0 ]; do
        case $1 in
            --desc)       [ $# -ge 2 ] || die "--desc requires a value"
                          _desc=$2; shift 2 ;;
            --blocked-by) [ $# -ge 2 ] || die "--blocked-by requires a value"
                          _blocked=$2; shift 2 ;;
            --role-hint)  [ $# -ge 2 ] || die "--role-hint requires a value"
                          _role_hint=$2; shift 2 ;;
            -*)           die "unknown flag: $1" ;;
            *)            [ -z "$_subject" ] || die "task add: too many arguments"
                          _subject=$1; shift ;;
        esac
    done
    [ -n "$_subject" ] || die "task add: missing <subject>"
    load_endpoint
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_T_SUBJ=$_subject \
                WODOUYAO_T_DESC=$_desc \
                WODOUYAO_T_BY=${WODOUYAO_ID:-user} \
                WODOUYAO_T_BLOCK=$_blocked \
                WODOUYAO_T_WS=${WODOUYAO_WORKSPACE_ID:-} \
                WODOUYAO_T_ROLE=${_role_hint} \
                python3 -c '
import json, os
obj = {"subject": os.environ["WODOUYAO_T_SUBJ"],
       "created_by": os.environ.get("WODOUYAO_T_BY", "user")}
d = os.environ.get("WODOUYAO_T_DESC", "")
if d:
    obj["description"] = d
b = os.environ.get("WODOUYAO_T_BLOCK", "")
blk = [x.strip() for x in b.split(",") if x.strip()]
if blk:
    obj["blocked_by"] = blk
ws = os.environ.get("WODOUYAO_T_WS", "")
if ws:
    obj["workspace_id"] = ws
r = os.environ.get("WODOUYAO_T_ROLE", "")
if r:
    obj["role_hint"] = r
print(json.dumps(obj))
')
    else
        _s_j=$(json_escape "$_subject")
        _by_j=$(json_escape "${WODOUYAO_ID:-user}")
        _body="{\"subject\":$_s_j,\"created_by\":$_by_j"
        if [ -n "$_desc" ]; then
            _d_j=$(json_escape "$_desc")
            _body="$_body,\"description\":$_d_j"
        fi
        if [ -n "${WODOUYAO_WORKSPACE_ID:-}" ]; then
            _ws_j=$(json_escape "$WODOUYAO_WORKSPACE_ID")
            _body="$_body,\"workspace_id\":$_ws_j"
        fi
        if [ -n "$_role_hint" ]; then
            _rh_j=$(json_escape "$_role_hint")
            _body="$_body,\"role_hint\":$_rh_j"
        fi
        _body="$_body}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/tasks") \
        || { rm -f "$_tmp"; die "task add failed"; }
    case $_code in
        200|201)
            _tid=$(extract_field id "$_tmp")
            rm -f "$_tmp"
            [ -n "$_tid" ] || die "task add: response missing id"
            printf '%s\n' "$_tid"
            ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "task add failed (HTTP $_code): $_err" ;;
    esac
}

cmd_task_take() {
    [ $# -ge 1 ] || die "task take: usage <task-id>"
    _tid=$1
    load_endpoint
    _by_j=$(json_escape "${WODOUYAO_ID:-}")
    _body="{\"owner_term_id\":$_by_j,\"status\":\"in_progress\"}"
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X PATCH -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/tasks/$_tid") \
        || { rm -f "$_tmp"; die "task take failed"; }
    case $_code in
        200) rm -f "$_tmp" ;;
        404) rm -f "$_tmp"; die "task not found: $_tid" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "task take failed (HTTP $_code): $_err" ;;
    esac
}

cmd_task_done() {
    [ $# -ge 1 ] || die "task done: usage <task-id>"
    _tid=$1
    load_endpoint
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X PATCH -H 'Content-Type: application/json' \
        --data-binary '{"status":"completed"}' "$URL/v1/tasks/$_tid") \
        || { rm -f "$_tmp"; die "task done failed"; }
    case $_code in
        200) rm -f "$_tmp" ;;
        404) rm -f "$_tmp"; die "task not found: $_tid" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "task done failed (HTTP $_code): $_err" ;;
    esac
}

cmd_task_update() {
    [ $# -ge 1 ] || die "task update: usage <task-id> [--status S] [--owner O] [--desc D]"
    _tid=$1; shift
    _status=""
    _owner=""
    _desc=""
    while [ $# -gt 0 ]; do
        case $1 in
            --status) [ $# -ge 2 ] || die "--status requires a value"
                      _status=$2; shift 2 ;;
            --owner)  [ $# -ge 2 ] || die "--owner requires a value"
                      _owner=$2; shift 2 ;;
            --desc)   [ $# -ge 2 ] || die "--desc requires a value"
                      _desc=$2; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    load_endpoint
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_P_STATUS=$_status \
                WODOUYAO_P_OWNER=$_owner \
                WODOUYAO_P_DESC=$_desc \
                python3 -c '
import json, os
obj = {}
s = os.environ.get("WODOUYAO_P_STATUS", "")
if s:
    obj["status"] = s
o = os.environ.get("WODOUYAO_P_OWNER", "")
if o:
    obj["owner_term_id"] = o
d = os.environ.get("WODOUYAO_P_DESC", "")
if d:
    obj["description"] = d
print(json.dumps(obj))
')
    else
        _body="{"
        _sep=""
        if [ -n "$_status" ]; then
            _s_j=$(json_escape "$_status")
            _body="$_body\"status\":$_s_j"
            _sep=","
        fi
        if [ -n "$_owner" ]; then
            _o_j=$(json_escape "$_owner")
            _body="$_body${_sep}\"owner_term_id\":$_o_j"
            _sep=","
        fi
        if [ -n "$_desc" ]; then
            _d_j=$(json_escape "$_desc")
            _body="$_body${_sep}\"description\":$_d_j"
        fi
        _body="$_body}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X PATCH -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/tasks/$_tid") \
        || { rm -f "$_tmp"; die "task update failed"; }
    case $_code in
        200) rm -f "$_tmp" ;;
        404) rm -f "$_tmp"; die "task not found: $_tid" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "task update failed (HTTP $_code): $_err" ;;
    esac
}

cmd_task_remove() {
    [ $# -ge 1 ] || die "task remove: usage <task-id>"
    _tid=$1
    load_endpoint
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X DELETE "$URL/v1/tasks/$_tid") \
        || die "task remove failed"
    case $_code in
        204) : ;;
        404) die "task not found: $_tid" ;;
        *)   die "task remove failed (HTTP $_code)" ;;
    esac
}

cmd_task_next() {
    _role=""
    while [ $# -gt 0 ]; do
        case $1 in
            --role) [ $# -ge 2 ] || die "--role requires a value"
                    _role=$2; shift 2 ;;
            -*)     die "unknown flag: $1" ;;
            *)      die "task next: unexpected arg: $1" ;;
        esac
    done
    load_endpoint
    _qs=""
    [ -n "$_role" ] && _qs="?role=$_role"
    _tmp=$(mktemp -t wd-task-next.XXXXXX) || die "mktemp failed"
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        "$URL/v1/tasks/next$_qs") || { rm -f "$_tmp"; die "task next failed"; }
    case $_code in
        200) cat "$_tmp"; printf '\n'; rm -f "$_tmp" ;;
        204) rm -f "$_tmp"; exit 3 ;;  # no eligible task
        *)   _msg=$(cat "$_tmp"); rm -f "$_tmp"; die "task next failed (HTTP $_code): $_msg" ;;
    esac
}

cmd_task_claim() {
    [ $# -ge 1 ] || die "task claim: usage <task-id>"
    _tid=$1
    [ -n "${WODOUYAO_ID:-}" ] || die "task claim: WODOUYAO_ID is unset"
    load_endpoint
    _tmp=$(mktemp -t wd-task-claim.XXXXXX) || die "mktemp failed"
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST "$URL/v1/tasks/$_tid/claim?from=$WODOUYAO_ID") \
        || { rm -f "$_tmp"; die "task claim failed"; }
    case $_code in
        200) cat "$_tmp"; printf '\n'; rm -f "$_tmp" ;;
        409) printf '%s: task already claimed: %s\n' "$SELF" "$_tid" >&2
             cat "$_tmp" >&2; printf '\n' >&2; rm -f "$_tmp"; exit 5 ;;
        404) rm -f "$_tmp"; die "task not found: $_tid" ;;
        *)   _msg=$(cat "$_tmp"); rm -f "$_tmp"; die "task claim failed (HTTP $_code): $_msg" ;;
    esac
}

# wodouyao task doc <sub> ...
#   list <task-id>
#   add  <task-id> <name> [--file PATH | --content TEXT]
#   cat  <task-id> <name>
#   rm   <task-id> <name>
cmd_task_doc() {
    [ $# -gt 0 ] || die "task doc: missing subcommand (list|add|cat|rm)"
    _sub=$1; shift
    case $_sub in
        list) cmd_task_doc_list "$@" ;;
        add)  cmd_task_doc_add  "$@" ;;
        cat)  cmd_task_doc_cat  "$@" ;;
        rm)   cmd_task_doc_rm   "$@" ;;
        *)    die "task doc: unknown subcommand: $_sub" ;;
    esac
}

cmd_task_doc_list() {
    [ $# -ge 1 ] || die "task doc list: usage <task-id>"
    _tid=$1
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/tasks/$_tid/docs") || die "task doc list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
    for name in d.get("docs", []):
        print(name)
except Exception:
    sys.exit(0)
'
    else
        printf '%s\n' "$_body"
    fi
}

cmd_task_doc_add() {
    [ $# -ge 2 ] || die "task doc add: usage <task-id> <name> [--file PATH | --content TEXT]"
    _tid=$1; _name=$2; shift 2
    _content=""
    _file=""
    while [ $# -gt 0 ]; do
        case $1 in
            --file)    [ $# -ge 2 ] || die "--file requires a value"
                       _file=$2; shift 2 ;;
            --content) [ $# -ge 2 ] || die "--content requires a value"
                       _content=$2; shift 2 ;;
            -*)        die "unknown flag: $1" ;;
            *)         die "task doc add: unexpected arg: $1" ;;
        esac
    done
    if [ -n "$_file" ]; then
        [ -f "$_file" ] || die "task doc add: file not found: $_file"
        _content=$(cat "$_file")
    fi
    load_endpoint
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WD_NAME=$_name WD_CONTENT=$_content python3 -c '
import json, os
print(json.dumps({"name": os.environ["WD_NAME"],
                  "content": os.environ.get("WD_CONTENT", "")}))
')
    else
        _n_j=$(json_escape "$_name")
        _c_j=$(json_escape "$_content")
        _body="{\"name\":$_n_j,\"content\":$_c_j}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/tasks/$_tid/docs") \
        || { rm -f "$_tmp"; die "task doc add failed"; }
    case $_code in
        200) cat "$_tmp"; printf '\n'; rm -f "$_tmp" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "task doc add failed (HTTP $_code): $_err" ;;
    esac
}

cmd_task_doc_cat() {
    [ $# -ge 2 ] || die "task doc cat: usage <task-id> <name>"
    _tid=$1; _name=$2
    load_endpoint
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        "$URL/v1/tasks/$_tid/docs/$_name") \
        || { rm -f "$_tmp"; die "task doc cat failed"; }
    case $_code in
        200)
            if command -v python3 >/dev/null 2>&1; then
                python3 -c '
import json, sys
d = json.load(open(sys.argv[1]))
print(d.get("content", ""), end="")
' "$_tmp"
            else
                cat "$_tmp"
            fi
            rm -f "$_tmp"
            ;;
        404) rm -f "$_tmp"; die "doc not found" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "task doc cat failed (HTTP $_code): $_err" ;;
    esac
}

cmd_task_doc_rm() {
    [ $# -ge 2 ] || die "task doc rm: usage <task-id> <name>"
    _tid=$1; _name=$2
    load_endpoint
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X DELETE "$URL/v1/tasks/$_tid/docs/$_name") \
        || die "task doc rm failed"
    case $_code in
        204) : ;;
        404) die "doc or task not found" ;;
        *)   die "task doc rm failed (HTTP $_code)" ;;
    esac
}

cmd_task() {
    [ $# -gt 0 ] || die "task: missing subcommand (list|add|next|claim|take|done|update|remove|doc)"
    _sub=$1; shift
    case $_sub in
        list)   cmd_task_list   "$@" ;;
        add)    cmd_task_add    "$@" ;;
        next)   cmd_task_next   "$@" ;;
        claim)  cmd_task_claim  "$@" ;;
        take)   cmd_task_take   "$@" ;;
        done)   cmd_task_done   "$@" ;;
        update) cmd_task_update "$@" ;;
        remove) cmd_task_remove "$@" ;;
        doc)    cmd_task_doc    "$@" ;;
        *)      die "task: unknown subcommand: $_sub" ;;
    esac
}

# ── Wire commands ────────────────────────────────────────────────────

cmd_wire_list() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/wires") || die "wire list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    wires = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for w in wires:
    kind = w.get("kind") or ""
    line = "%s  %s -> %s" % (w.get("id", ""), w.get("source_id", ""), w.get("target_id", ""))
    if kind:
        line += "  [%s]" % kind
    print(line)
'
    else
        printf '%s\n' "$_body"
    fi
}

cmd_wire_add() {
    _source=""
    _target=""
    _kind=""
    while [ $# -gt 0 ]; do
        case $1 in
            --kind) [ $# -ge 2 ] || die "--kind requires a value"
                    _kind=$2; shift 2 ;;
            -*)     die "unknown flag: $1" ;;
            *)      if [ -z "$_source" ]; then _source=$1
                    elif [ -z "$_target" ]; then _target=$1
                    else die "wire add: too many arguments"
                    fi
                    shift ;;
        esac
    done
    [ -n "$_source" ] || die "wire add: missing <source-id>"
    [ -n "$_target" ] || die "wire add: missing <target-id>"
    load_endpoint
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_W_SRC=$_source \
                WODOUYAO_W_TGT=$_target \
                WODOUYAO_W_KIND=$_kind \
                python3 -c '
import json, os
obj = {"source_id": os.environ["WODOUYAO_W_SRC"],
       "target_id": os.environ["WODOUYAO_W_TGT"]}
k = os.environ.get("WODOUYAO_W_KIND", "")
if k:
    obj["kind"] = k
print(json.dumps(obj))
')
    else
        _s_j=$(json_escape "$_source")
        _t_j=$(json_escape "$_target")
        _body="{\"source_id\":$_s_j,\"target_id\":$_t_j"
        if [ -n "$_kind" ]; then
            _k_j=$(json_escape "$_kind")
            _body="$_body,\"kind\":$_k_j"
        fi
        _body="$_body}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/wires") \
        || { rm -f "$_tmp"; die "wire add failed"; }
    case $_code in
        200)
            _wid=$(extract_field id "$_tmp")
            rm -f "$_tmp"
            printf '%s\n' "$_wid"
            ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "wire add failed (HTTP $_code): $_err" ;;
    esac
}

cmd_wire_remove() {
    [ $# -ge 1 ] || die "wire remove: usage <wire-id>"
    _wid=$1
    load_endpoint
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X DELETE "$URL/v1/wires/$_wid") \
        || die "wire remove failed"
    case $_code in
        204) : ;;
        404) die "wire not found: $_wid" ;;
        *)   die "wire remove failed (HTTP $_code)" ;;
    esac
}

cmd_wire() {
    [ $# -gt 0 ] || die "wire: missing subcommand (list|add|remove)"
    _sub=$1; shift
    case $_sub in
        list)   cmd_wire_list   "$@" ;;
        add)    cmd_wire_add    "$@" ;;
        remove) cmd_wire_remove "$@" ;;
        *)      die "wire: unknown subcommand: $_sub" ;;
    esac
}

# ── Note commands ────────────────────────────────────────────────────

cmd_note_list() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/notes") || die "note list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    notes = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for n in notes:
    text = (n.get("text") or "")[:60].replace("\n", "\\n")
    print("%s  %s" % (n.get("id", ""), text))
'
    else
        printf '%s\n' "$_body"
    fi
}

cmd_note_add() {
    _text=""
    _color=""
    while [ $# -gt 0 ]; do
        case $1 in
            --color) [ $# -ge 2 ] || die "--color requires a value"
                     _color=$2; shift 2 ;;
            -*)      die "unknown flag: $1" ;;
            *)       [ -z "$_text" ] || die "note add: too many arguments"
                     _text=$1; shift ;;
        esac
    done
    [ -n "$_text" ] || die "note add: missing <text>"
    load_endpoint
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WODOUYAO_N_TEXT=$_text \
                WODOUYAO_N_COLOR=$_color \
                python3 -c '
import json, os
obj = {"text": os.environ["WODOUYAO_N_TEXT"]}
c = os.environ.get("WODOUYAO_N_COLOR", "")
if c:
    obj["color"] = c
print(json.dumps(obj))
')
    else
        _t_j=$(json_escape "$_text")
        _body="{\"text\":$_t_j"
        if [ -n "$_color" ]; then
            _c_j=$(json_escape "$_color")
            _body="$_body,\"color\":$_c_j"
        fi
        _body="$_body}"
    fi
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/notes") \
        || { rm -f "$_tmp"; die "note add failed"; }
    case $_code in
        200)
            _nid=$(extract_field id "$_tmp")
            rm -f "$_tmp"
            printf '%s\n' "$_nid"
            ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "note add failed (HTTP $_code): $_err" ;;
    esac
}

cmd_note_update() {
    [ $# -ge 2 ] || die "note update: usage <note-id> <text>"
    _nid=$1; shift
    _text=$*
    load_endpoint
    _t_j=$(json_escape "$_text")
    _body="{\"text\":$_t_j}"
    _tmp=$(mktemp)
    _code=$(curl_auth -o "$_tmp" -w '%{http_code}' \
        -X PATCH -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/notes/$_nid") \
        || { rm -f "$_tmp"; die "note update failed"; }
    case $_code in
        200) rm -f "$_tmp" ;;
        404) rm -f "$_tmp"; die "note not found: $_nid" ;;
        *)   _err=$(cat "$_tmp"); rm -f "$_tmp"
             die "note update failed (HTTP $_code): $_err" ;;
    esac
}

cmd_note_remove() {
    [ $# -ge 1 ] || die "note remove: usage <note-id>"
    _nid=$1
    load_endpoint
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X DELETE "$URL/v1/notes/$_nid") \
        || die "note remove failed"
    case $_code in
        204) : ;;
        404) die "note not found: $_nid" ;;
        *)   die "note remove failed (HTTP $_code)" ;;
    esac
}

cmd_note() {
    [ $# -gt 0 ] || die "note: missing subcommand (list|add|update|remove)"
    _sub=$1; shift
    case $_sub in
        list)   cmd_note_list   "$@" ;;
        add)    cmd_note_add    "$@" ;;
        update) cmd_note_update "$@" ;;
        remove) cmd_note_remove "$@" ;;
        *)      die "note: unknown subcommand: $_sub" ;;
    esac
}

# ── Terminal commands ────────────────────────────────────────────────

cmd_terminal_list() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/terminals") || die "terminal list failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
try:
    terms = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for t in terms:
    line = t.get("id", "")
    name = t.get("name") or ""
    kind = t.get("agent_kind") or ""
    if name:
        line += "  %s" % name
    if kind:
        line += "  [%s]" % kind
    print(line)
'
    else
        printf '%s\n' "$_body"
    fi
}

cmd_terminal_close() {
    [ $# -ge 1 ] || die "terminal close: usage <terminal-id>"
    _tid=$1
    load_endpoint
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X DELETE "$URL/v1/terminals/$_tid") \
        || die "terminal close failed"
    case $_code in
        204) : ;;
        404) die "terminal not found: $_tid" ;;
        *)   die "terminal close failed (HTTP $_code)" ;;
    esac
}

cmd_terminal_set_session() {
    [ $# -ge 1 ] || die "terminal set-session: usage <session-id> | -"
    _sid=$1
    [ -n "${WODOUYAO_ID:-}" ] || die "terminal set-session: WODOUYAO_ID is unset"
    # When invoked from a Claude Code SessionStart hook the session id
    # arrives as JSON on stdin: {"session_id":"...","transcript_path":"...",...}
    # Pass `-` as the argument and we extract it without needing python.
    if [ "$_sid" = "-" ]; then
        _stdin=$(cat)
        # Greedy match for the first "session_id":"..." occurrence. Good
        # enough for Claude Code's hook payload (single-line JSON, no
        # nested session_id keys).
        _sid=$(printf '%s' "$_stdin" | sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)
        [ -n "$_sid" ] || die "terminal set-session: could not parse session_id from stdin"
    fi
    load_endpoint
    _body=$(printf '{"session_id":"%s"}' "$_sid")
    _code=$(curl_auth -o /dev/null -w '%{http_code}' \
        -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/terminals/$WODOUYAO_ID/session") \
        || die "terminal set-session failed"
    case $_code in
        204) : ;;
        *)   die "terminal set-session failed (HTTP $_code)" ;;
    esac
}

cmd_terminal() {
    [ $# -gt 0 ] || die "terminal: missing subcommand (list|close|set-session)"
    _sub=$1; shift
    case $_sub in
        list)        cmd_terminal_list  "$@" ;;
        close)       cmd_terminal_close "$@" ;;
        set-session) cmd_terminal_set_session "$@" ;;
        *)           die "terminal: unknown subcommand: $_sub" ;;
    esac
}

cmd_bg_get() {
    load_endpoint
    curl_auth -f "$URL/v1/background" || die "bg get failed"
    printf '\n'
}

cmd_bg_shaders() {
    load_endpoint
    _body=$(curl_auth -f "$URL/v1/shaders") || die "bg shaders failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_body" | python3 -c '
import json, sys
for n in json.load(sys.stdin):
    print(n)
'
    else
        printf '%s' "$_body" \
            | grep -o '"[^"]*"' \
            | sed 's/"//g'
    fi
}

cmd_bg_set() {
    # cmd_bg_set <kind> [--source S] [--shader N] [--opacity F]
    [ $# -gt 0 ] || die "bg set: missing kind (none|image|video|url|shader)"
    _kind=$1; shift
    case $_kind in
        none|image|video|url|shader) ;;
        *) die "bg set: invalid kind: $_kind" ;;
    esac
    _fields="\"kind\":$(json_escape "$_kind")"
    while [ $# -gt 0 ]; do
        case $1 in
            --source)  shift; _fields="$_fields,\"source\":$(json_escape "${1:-}")" ;;
            --shader)  shift; _fields="$_fields,\"shader\":$(json_escape "${1:-}")" ;;
            --opacity) shift; _fields="$_fields,\"opacity\":${1:-1.0}" ;;
            *) die "bg set: unknown flag: $1" ;;
        esac
        shift || true
    done
    load_endpoint
    _body="{$_fields}"
    curl_auth -f -X POST -H "Content-Type: application/json" \
        --data-binary "$_body" "$URL/v1/background" >/dev/null \
        || die "bg set failed"
}

cmd_workflow() {
    [ $# -gt 0 ] || die "workflow: missing subcommand (init)"
    _sub=$1; shift
    case $_sub in
        init) cmd_workflow_init "$@" ;;
        *)    die "workflow: unknown subcommand: $_sub" ;;
    esac
}

# wodouyao workflow init [--with role1,role2,...] [--mesh] [--cwd PATH]
# Spawns one terminal per role, wires them in a star (or mesh with --mesh),
# and injects per-role system prompts. Default role set: pm,backend,frontend.
cmd_workflow_init() {
    _with="pm,backend,frontend"
    _mesh="false"
    _cwd=""
    while [ $# -gt 0 ]; do
        case $1 in
            --with) [ $# -ge 2 ] || die "--with requires a value"
                    _with=$2; shift 2 ;;
            --mesh) _mesh="true"; shift ;;
            --cwd)  [ $# -ge 2 ] || die "--cwd requires a value"
                    _cwd=$2; shift 2 ;;
            -*)     die "unknown flag: $1" ;;
            *)      die "workflow init: unexpected arg: $1" ;;
        esac
    done
    load_endpoint
    # Compose JSON. Use python3 for safety; fall back to a hand-rolled string
    # if python3 isn't around (works since roles are simple identifiers).
    if command -v python3 >/dev/null 2>&1; then
        _body=$(WD_WITH=$_with WD_MESH=$_mesh WD_CWD=$_cwd python3 -c '
import json, os
roles = [r.strip() for r in os.environ["WD_WITH"].split(",") if r.strip()]
body = {"roles": [{"role": r} for r in roles],
        "wire_mesh": os.environ["WD_MESH"] == "true"}
cwd = os.environ.get("WD_CWD", "")
if cwd: body["cwd"] = cwd
print(json.dumps(body))
')
    else
        _entries=""
        _IFS_save=$IFS; IFS=,
        for r in $_with; do
            [ -n "$r" ] || continue
            _entries="${_entries}${_entries:+,}{\"role\":\"$r\"}"
        done
        IFS=$_IFS_save
        _body="{\"roles\":[$_entries],\"wire_mesh\":$_mesh"
        [ -n "$_cwd" ] && _body="$_body,\"cwd\":\"$_cwd\""
        _body="$_body}"
    fi
    _resp=$(curl_auth -f -X POST -H 'Content-Type: application/json' \
        --data-binary "$_body" "$URL/v1/workflow/bootstrap") \
        || die "workflow init failed"
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "$_resp" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
    for tid in d.get("terminal_ids", []):
        print(tid)
except Exception:
    sys.exit(0)
'
    else
        printf '%s\n' "$_resp"
    fi
}

cmd_bg() {
    [ $# -gt 0 ] || die "bg: missing subcommand (get|set|shaders)"
    _sub=$1; shift
    case $_sub in
        get)     cmd_bg_get "$@" ;;
        set)     cmd_bg_set "$@" ;;
        shaders) cmd_bg_shaders "$@" ;;
        *)       die "bg: unknown subcommand: $_sub" ;;
    esac
}

[ $# -gt 0 ] || usage
sub=$1; shift
case $sub in
    peers)          cmd_peers "$@" ;;
    whoami)         cmd_whoami "$@" ;;
    hello)          cmd_hello "$@" ;;
    spawn)          cmd_spawn "$@" ;;
    fork)           cmd_fork  "$@" ;;
    send)           cmd_send  "$@" ;;
    read)           cmd_read  "$@" ;;
    watch)          cmd_watch "$@" ;;
    team)           cmd_team  "$@" ;;
    task)           cmd_task  "$@" ;;
    wire)           cmd_wire  "$@" ;;
    note)           cmd_note  "$@" ;;
    terminal)       cmd_terminal "$@" ;;
    bg)             cmd_bg "$@" ;;
    workflow)       cmd_workflow "$@" ;;
    -h|--help|help) usage 0 ;;
    *)              die "unknown subcommand: $sub" ;;
esac
